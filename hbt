-- ══════════════════════════
--     LOADING OVERLAY
-- ══════════════════════════
local function showLoadingScreen(callback)
    local lsg = new("ScreenGui", {
        Parent = (gethui and gethui()) or game:GetService("CoreGui"),
        Name = "skyhub_loading",
        ZIndexBehavior = Enum.ZIndexBehavior.Global,
        ResetOnSpawn = false,
        IgnoreGuiInset = true,
    })

    local bg = new("Frame", {
        Parent = lsg,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Color3.fromRGB(5, 7, 14),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
    })

    -- fade in background
    tw(bg, { BackgroundTransparency = 0 }, 0.3)

    local logo = new("TextLabel", {
        Parent = bg,
        Size = UDim2.new(1, 0, 0, 50),
        Position = UDim2.new(0, 0, 0.5, -70),
        BackgroundTransparency = 1,
        Text = "SKYHUB",
        Font = Enum.Font.GothamBold,
        TextSize = 40,
        TextColor3 = Color3.fromRGB(48, 120, 220),
        TextXAlignment = Enum.TextXAlignment.Center,
        TextTransparency = 1,
    })

    local statusLbl = new("TextLabel", {
        Parent = bg,
        Size = UDim2.new(1, 0, 0, 20),
        Position = UDim2.new(0, 0, 0.5, -10),
        BackgroundTransparency = 1,
        Text = "Se incarca scriptul...",
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextColor3 = Color3.fromRGB(195, 215, 255),
        TextXAlignment = Enum.TextXAlignment.Center,
        TextTransparency = 1,
    })

    local barBg2 = new("Frame", {
        Parent = bg,
        Size = UDim2.new(0, 260, 0, 3),
        Position = UDim2.new(0.5, -130, 0.5, 22),
        BackgroundColor3 = Color3.fromRGB(20, 30, 55),
        BorderSizePixel = 0,
        BackgroundTransparency = 1,
    })
    corner(barBg2, 2)

    local barFill2 = new("Frame", {
        Parent = barBg2,
        Size = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = Color3.fromRGB(48, 120, 220),
        BorderSizePixel = 0,
    })
    corner(barFill2, 2)

    -- animate in
    task.wait(0.1)
    tw(logo,      { TextTransparency = 0 }, 0.4)
    tw(statusLbl, { TextTransparency = 0 }, 0.4)
    tw(barBg2,    { BackgroundTransparency = 0 }, 0.4)

    -- fake progress bar animatie
    tw(barFill2, { Size = UDim2.new(0.7, 0, 1, 0) }, 0.8, Enum.EasingStyle.Quad)

    task.wait(0.6)

    -- ruleaza scriptul
    local ok, err = pcall(callback)

    -- completeaza bara
    tw(barFill2, { Size = UDim2.new(1, 0, 1, 0) }, 0.3, Enum.EasingStyle.Quad)
    task.wait(0.35)

    if ok then
        statusLbl.Text = "Incarcat cu succes ✓"
        statusLbl.TextColor3 = Color3.fromRGB(60, 220, 100)
    else
        statusLbl.Text = "Eroare la incarcare!"
        statusLbl.TextColor3 = Color3.fromRGB(220, 60, 60)
        task.wait(1.5)
    end

    task.wait(0.5)

    -- fade out
    tw(logo,      { TextTransparency = 1 }, 0.35)
    tw(statusLbl, { TextTransparency = 1 }, 0.35)
    tw(barFill2,  { BackgroundTransparency = 1 }, 0.35)
    tw(barBg2,    { BackgroundTransparency = 1 }, 0.35)
    tw(bg,        { BackgroundTransparency = 1 }, 0.45)
    task.wait(0.5)
    lsg:Destroy()
end

