    Parent = sg,
    Size = UDim2.new(0, 560, 0, 400),
    Position = UDim2.new(0, 14, 0.5, 0),
    AnchorPoint = Vector2.new(0, 0.5),
    BackgroundColor3 = C.bg,
    BorderSizePixel = 0,
    ClipsDescendants = true,
})
corner(win, 7)
stroke(win, C.border, 1)

-- topbar
local top = new("Frame", { Parent = win, Size = UDim2.new(1, 0, 0, 32), BackgroundColor3 = C.sidebar, BorderSizePixel = 0 })
corner(top, 7)
new("Frame", { Parent = top, Size = UDim2.new(1, 0, 0, 1), Position = UDim2.new(0, 0, 1, -1), BackgroundColor3 = C.accent, BorderSizePixel = 0 })
new("TextLabel", { Parent = top, Size = UDim2.new(0, 140, 1, 0), Position = UDim2.new(0, 10, 0, 0), BackgroundTransparency = 1, Text = "SKYHUB", Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = C.accent, TextXAlignment = Enum.TextXAlignment.Left })
new("TextLabel", { Parent = top, Size = UDim2.new(0, 30, 1, 0), Position = UDim2.new(0, 90, 0, 0), BackgroundTransparency = 1, Text = "v1", Font = Enum.Font.Gotham, TextSize = 10, TextColor3 = C.txtmut, TextXAlignment = Enum.TextXAlignment.Left })

-- drag
local drag, ds, sp = false, nil, nil
top.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        drag = true; ds = i.Position; sp = win.Position
        i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then drag = false end end)
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
        local d = i.Position - ds
        win.Position = UDim2.new(sp.X.Scale, sp.X.Offset + d.X, sp.Y.Scale, sp.Y.Offset + d.Y)
    end
end)

-- minimize
local minimized = false
local minbtn = new("TextButton", { Parent = top, Size = UDim2.new(0, 22, 0, 16), Position = UDim2.new(1, -28, 0.5, -8), BackgroundColor3 = C.accent, BorderSizePixel = 0, Text = "-", Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = C.white, AutoButtonColor = false })
corner(minbtn, 4)
minbtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    TweenService:Create(win, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Size = minimized and UDim2.new(0, 560, 0, 32) or UDim2.new(0, 560, 0, 400) }):Play()
    minbtn.Text = minimized and "+" or "-"
end)

