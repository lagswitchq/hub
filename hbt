    { name = "Heavy Rust",     github = "--AICI BAGI GITHUB TAB 2" },
    { name = "Sniper Or Swap", github = "--AICI BAGI GITHUB TAB 3" },
    { name = "War Tycoon",     github = "--AICI BAGI GITHUB TAB 4" },
    { name = "Counter Blox",   github = "--AICI BAGI GITHUB TAB 5" },
    { name = "The Armory",     github = "--AICI BAGI GITHUB TAB 6" },
    { name = "Rivals",         github = "--AICI BAGI GITHUB TAB 7" },
    { name = "Rost",           github = "--AICI BAGI GITHUB TAB 8" },
} 

local function makeTab(def, idx)
    local btn = new("TextButton", { Parent = tabList, Size = UDim2.new(1, 0, 0, 30), BackgroundColor3 = C.sidebar, BorderSizePixel = 0, Text = "", AutoButtonColor = false })
    corner(btn, 5)
    local lbl = new("TextLabel", { Parent = btn, Size = UDim2.new(1, -10, 1, 0), Position = UDim2.new(0, 10, 0, 0), BackgroundTransparency = 1, Text = def.name, Font = Enum.Font.Gotham, TextSize = 11, TextColor3 = C.txtdim, TextXAlignment = Enum.TextXAlignment.Left })
    local bar = new("Frame", { Parent = btn, Size = UDim2.new(0, 3, 0, 16), Position = UDim2.new(0, 0, 0.5, -8), BackgroundColor3 = C.accent, BorderSizePixel = 0, BackgroundTransparency = 1 })
    corner(bar, 3)

    local page = new("ScrollingFrame", { Parent = content, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, BorderSizePixel = 0, ScrollBarThickness = 2, ScrollBarImageColor3 = C.accent, CanvasSize = UDim2.new(0,0,0,0), AutomaticCanvasSize = Enum.AutomaticSize.Y, Visible = false })
    local pp = Instance.new("UIPadding"); pp.PaddingTop = UDim.new(0,16); pp.PaddingLeft = UDim.new(0,16); pp.PaddingRight = UDim.new(0,12); pp.PaddingBottom = UDim.new(0,16); pp.Parent = page
    local pl = Instance.new("UIListLayout"); pl.Padding = UDim.new(0,10); pl.SortOrder = Enum.SortOrder.LayoutOrder; pl.Parent = page

    new("TextLabel", { Parent = page, Size = UDim2.new(1, 0, 0, 22), BackgroundTransparency = 1, Text = def.name, Font = Enum.Font.GothamBold, TextSize = 14, TextColor3 = C.accent, TextXAlignment = Enum.TextXAlignment.Left })

    local loadBtn = new("TextButton", { Parent = page, Size = UDim2.new(1, 0, 0, 34), BackgroundColor3 = C.accentD, BorderSizePixel = 0, Text = "Load Script", Font = Enum.Font.GothamSemibold, TextSize = 13, TextColor3 = C.txt, AutoButtonColor = false })
    corner(loadBtn, 5)
    stroke(loadBtn, C.accent, 1)

    loadBtn.MouseEnter:Connect(function() TweenService:Create(loadBtn, TweenInfo.new(0.1), { BackgroundColor3 = C.accent }):Play() end)
    loadBtn.MouseLeave:Connect(function() TweenService:Create(loadBtn, TweenInfo.new(0.1), { BackgroundColor3 = C.accentD }):Play() end)

    loadBtn.MouseButton1Click:Connect(function()
        if def.github:sub(1,2) == "--" then return end

        -- ascunde main gui
        TweenService:Create(win, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { BackgroundTransparency = 1, Size = UDim2.new(0, 560, 0, 0) }):Play()
        task.wait(0.28)
        win.Visible = false

        -- arata loading screen si ruleaza scriptul
        task.spawn(function()
            showLoadingScreen(function()
                loadstring(game:HttpGet(def.github))()
            end)
            -- dupa ce loading screen dispare, distruge tot
            sg:Destroy()
        end)
    end)

    local t = { btn=btn, page=page, bar=bar, lbl=lbl }
    tabs[idx] = t

    btn.MouseButton1Click:Connect(function()
        for _, v in ipairs(tabs) do
            v.page.Visible = false
            TweenService:Create(v.bar, TweenInfo.new(0.12), { BackgroundTransparency = 1 }):Play()
            TweenService:Create(v.lbl, TweenInfo.new(0.12), { TextColor3 = C.txtdim }):Play()
            TweenService:Create(v.btn, TweenInfo.new(0.12), { BackgroundColor3 = C.sidebar }):Play()
        end
        page.Visible = true
        TweenService:Create(bar, TweenInfo.new(0.12), { BackgroundTransparency = 0 }):Play()
        TweenService:Create(lbl, TweenInfo.new(0.12), { TextColor3 = C.txt }):Play()
        TweenService:Create(btn, TweenInfo.new(0.12), { BackgroundColor3 = C.elem }):Play()
    end)
end

for i, def in ipairs(tabDefs) do
    makeTab(def, i)
end

tabs[1].page.Visible = true
tabs[1].bar.BackgroundTransparency = 0
tabs[1].lbl.TextColor3 = C.txt
tabs[1].btn.BackgroundColor3 = C.elem

-- open anim
win.Size = UDim2.new(0, 560, 0, 0)
win.BackgroundTransparency = 1
TweenService:Create(win, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Size = UDim2.new(0, 560, 0, 400), BackgroundTransparency = 0 }):Play()

end -- buildMainGui
